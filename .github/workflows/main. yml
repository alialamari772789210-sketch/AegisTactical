    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Grant permissions
        run: |
          # التأكد من وجود الملف قبل إعطاء الأمر
          if [ -f "./gradlew" ]; then
            chmod +x ./gradlew
            echo "Success: gradlew found and armed."
          else
            echo "Error: gradlew not found in root!"
            exit 1
          fi
          
          if [ -f "./sync.sh" ]; then
            chmod +x ./sync.sh
          fi
